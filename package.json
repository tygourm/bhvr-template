{
  "packageManager": "bun@1.3.14",
  "name": "bhvr-template",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "conf/*",
    "libs/*"
  ],
  "scripts": {
    "start": "bun run --filter './apps/*' start",
    "build": "bun run --filter './apps/web' build",
    "serve": "bun run --filter './apps/api' serve",
    "write": "prettier -w . && bun run --workspaces write",
    "check": "prettier -c . && bun run --workspaces check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "proseWrap": "always"
  }
}
